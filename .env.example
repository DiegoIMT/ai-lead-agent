# ================================
# AI Lead Qualification Agent
# Environment Variables
# ================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Webhook Configuration
# Internal test webhook (enabled by default)
WEBHOOK_INTERNAL_ENABLED=true

# External webhook URL (optional - leave empty to skip)
WEBHOOK_EXTERNAL_URL=

# External webhook secret for signature (optional)
WEBHOOK_SECRET=your_webhook_secret_here

# OpenAI Integration (optional - app works without it via local fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Enrichment APIs (optional - mocks used when not set)
CLEARBIT_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# Logging
LOG_LEVEL=dev

# Lead History
MAX_HISTORY_SIZE=50
